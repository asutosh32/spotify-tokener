modules = ["go-1.21", "go-1.25"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "GOTOOLCHAIN=local SPOTIFY_TOKENER_ADDR=0.0.0.0:5000 SPOTIFY_TOKENER_CHROME_PATH=/nix/store/qa9cnw4v5xkxyip6mb9kxqfq1z4x2dx1-chromium-138.0.7204.100/bin/chromium go run -mod=mod ."
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "GOTOOLCHAIN=local SPOTIFY_TOKENER_ADDR=0.0.0.0:5000 SPOTIFY_TOKENER_CHROME_PATH=/nix/store/qa9cnw4v5xkxyip6mb9kxqfq1z4x2dx1-chromium-138.0.7204.100/bin/chromium ./spotify-tokener"]
build = ["go", "build", "-o", "spotify-tokener", "."]
